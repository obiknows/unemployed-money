---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).toUpperCase();
}
---

<Layout title="Journal" description="A series of ideas & thoughts on trading and the markets.">
  <div class="py-4 my-2 border-b border-slate-200">
    <h1 class="mr-2 text-3xl font-black dark:text-white md:text-6xl">✍🏿 Journal</h1>
  </div>
  <div class="my-10">
    <span class="px-3 py-1 font-mono text-xs font-semibold leading-none tracking-wide text-white uppercase bg-red-800 rounded-full">
      SELLF REFLECTIONZ
    </span>
    <h1 class="mt-4 text-3xl leading-normal text-black transition-all ease-in-out dark:text-white md:text-5xl md:leading-snug">
      a series of ideas &amp; thoughts on trading and the markets, updated daily*
    </h1>
  </div>

  <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
    {posts.map(post => (
      <div class="flex flex-col items-center justify-center px-4 py-4 my-2 border-b rounded dark:bg-stone-600 hover:bg-amber-200 bg-amber-100 md:my-0 border-slate-200">
        <a href={`/posts/${post.id}`} class="no-underline hover:no-underline w-full text-center">
          <h2 class="my-2 text-center hover:underline hover:text-red-800">{post.data.title}</h2>
        </a>
        <div class="items-center leading-relaxed uppercase">
          <time>{formatDate(post.data.date)}</time>
        </div>
      </div>
    ))}
  </div>
</Layout>
