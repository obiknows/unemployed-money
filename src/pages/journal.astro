---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).toUpperCase();
}
---

<Layout title="Journal" description="A series of ideas & thoughts on trading and the markets.">
  <div class="my-2 border-b border-slate-200 py-4 dark:border-slate-600">
    <h1 class="mr-2 font-serif text-3xl font-black text-black dark:text-white md:text-6xl">✍🏿 Journal</h1>
  </div>
  <div class="my-10">
    <span class="rounded-full bg-red-800 px-3 py-1 font-mono text-xs font-semibold uppercase leading-none tracking-wide text-white">
      SELLF REFLECTIONZ
    </span>
    <h1 class="mt-4 font-serif text-3xl leading-normal text-black dark:text-white md:text-5xl md:leading-snug">
      a series of ideas &amp; thoughts on trading and the markets, updated daily*
    </h1>
  </div>

  <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
    {posts.map(post => (
      <div class="my-2 flex flex-col items-center justify-center rounded border-b border-slate-200 bg-amber-100 px-4 py-4 hover:bg-amber-200 dark:border-slate-600 dark:bg-stone-600 dark:hover:bg-stone-500 md:my-0">
        <a href={`/posts/${post.id}`} class="w-full text-center no-underline hover:no-underline">
          <h2 class="my-2 text-center font-serif text-base font-bold leading-snug text-black hover:underline hover:text-red-800 dark:text-white dark:hover:text-red-300 md:text-lg">{post.data.title}</h2>
        </a>
        <div class="font-sans uppercase leading-relaxed text-slate-500 dark:text-slate-300">
          <time>{formatDate(post.data.date)}</time>
        </div>
      </div>
    ))}
  </div>
</Layout>
