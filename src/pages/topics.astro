---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const tagCounts: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<Layout title="Topics" description="Browse all topics and tags from the Unemployed Money trading journal.">
  <div class="py-4 my-2 border-b border-slate-200">
    <h1 class="mr-2 text-3xl font-black md:text-6xl">📝 Topics</h1>
  </div>
  <ul class="mt-4 list-disc">
    {tags.map(([tag, count]) => (
      <li>
        <a href={`/tag/${tag}`} class="capitalize">{tag} ({count})</a>
      </li>
    ))}
  </ul>
</Layout>
