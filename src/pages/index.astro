---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

/** Homepage featured card order (matches original site). */
const FEATURED_ORDER = [
  'the-post-game-papers',
  'unemployed-money-4eva',
  'affirmations',
];

const featuredCandidates = posts.filter((p) => p.data.featured);
const featuredById = new Map(featuredCandidates.map((p) => [p.id, p]));
const orderedFeatured = FEATURED_ORDER.map((id) => featuredById.get(id)).filter(
  (p): p is (typeof featuredCandidates)[number] => p != null,
);
const extraFeatured = featuredCandidates.filter((p) => !FEATURED_ORDER.includes(p.id));
const featuredPosts = [...orderedFeatured, ...extraFeatured];

const journalPosts = posts.filter(p => !p.data.featured);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).toUpperCase();
}
---

<Layout title="Stackin Szn" description="One man's journey to get some unemployed money so he can spend more time with his family.">
  <!-- Hero -->
  <div class="my-10">
    <span class="px-3 py-1 font-mono text-xs font-semibold leading-none tracking-wide text-black uppercase rounded-full bg-amber-500 dark:text-black">
      Stackin Szn
    </span>
    <h1 class="mt-4 font-serif text-3xl leading-normal text-black dark:text-white md:text-5xl md:leading-snug">
      One man's journey to get some unemployed money so he can spend more time with his family.
    </h1>
  </div>

  <!-- Featured Posts -->
  <h2 class="pb-6 my-6 font-sans text-2xl font-semibold text-slate-600 dark:text-slate-400 md:text-3xl">Featured Posts</h2>
  <div class="grid grid-cols-1 gap-2 md:grid-cols-2 md:gap-8">
    {featuredPosts.map(post => (
      <a href={`/posts/${post.id}`} class="group flex h-full w-full flex-col overflow-hidden text-black no-underline hover:no-underline dark:text-white">
        {post.data.coverPhoto ? (
          <img
            class="h-[200px] w-full rounded-md object-cover"
            src={post.data.coverPhoto}
            alt=""
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="h-[200px] w-full rounded-md bg-amber-100 dark:bg-amber-900/30" />
        )}
        <div class="flex h-max w-full flex-col py-4 group-hover:text-red-800 dark:group-hover:text-red-400">
          <span class="mb-2 font-serif text-xl font-bold uppercase leading-snug">{post.data.title}</span>
        </div>
      </a>
    ))}
  </div>

  <!-- Journal Entries -->
  <h2 class="my-6 font-sans text-2xl font-semibold text-slate-600 dark:text-slate-400 md:text-3xl">Journal Entries</h2>
  <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
    {journalPosts.map(post => (
      <div class="my-2 flex flex-col items-center justify-center rounded border-b border-slate-200 bg-amber-100 px-4 py-4 hover:bg-amber-200 dark:border-slate-600 dark:bg-stone-600 dark:hover:bg-stone-500 md:my-0">
        <a href={`/posts/${post.id}`} class="w-full text-center no-underline hover:no-underline">
          <h2 class="my-2 text-center font-serif text-base font-bold leading-snug text-black hover:underline hover:text-red-800 dark:text-white dark:hover:text-red-300 md:text-lg">{post.data.title}</h2>
        </a>
        <div class="font-sans uppercase leading-relaxed text-slate-500 dark:text-slate-300">
          <time>{formatDate(post.data.date)}</time>
        </div>
      </div>
    ))}
  </div>
</Layout>
