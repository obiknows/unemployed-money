---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Slug not found');

const post = await getEntry('posts', slug);
if (!post) throw new Error('No post found for this slug');

const { Content } = await render(post);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).toUpperCase();
}
---

<Layout title={post.data.title} description={post.data.description}>
  <small class="text-sm font-bold tracking-tight uppercase">{formatDate(post.data.date)}</small>
  <article class="my-6 prose prose-green lg:prose-xl dark:prose-invert">
    <h1>{post.data.title}</h1>
    <Content />
  </article>
  {post.data.tags && post.data.tags.length > 0 && (
    <ul class="flex flex-row gap-4 mb-4 list-none p-0">
      {post.data.tags.map((tag: string) => (
        <li class="px-2 py-1 rounded-full bg-slate-100">
          <a href={`/tag/${tag}`}>{tag}</a>
        </li>
      ))}
    </ul>
  )}
</Layout>
