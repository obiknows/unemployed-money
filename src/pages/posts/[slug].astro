---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Giphy from '../../components/mdx/Giphy.astro';
import PostImage from '../../components/mdx/PostImage.astro';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) throw new Error('Slug not found');

const post = await getEntry('posts', slug);
if (!post) throw new Error('No post found for this slug');

const isPreview = Astro.url.searchParams.get('preview') === '1';
if (post.data.draft && !isPreview) {
  return Astro.redirect('/', 302);
}

const { Content } = await render(post);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).toUpperCase();
}
---

<Layout title={post.data.title} description={post.data.description}>
  <small class="font-sans text-sm font-bold uppercase tracking-tight text-slate-500 dark:text-slate-400">{formatDate(post.data.date)}</small>
  <article class="prose prose-green prose-headings:font-serif my-6 lg:prose-xl dark:prose-invert">
    <h1>{post.data.title}</h1>
    <Content components={{ Giphy, img: PostImage, Image: PostImage }} />
  </article>
  {post.data.tags && post.data.tags.length > 0 && (
    <ul class="mb-4 flex list-none flex-row flex-wrap gap-2 p-0 font-sans">
      {post.data.tags.map((tag: string) => (
        <li class="rounded-full bg-slate-100 px-2 py-1 dark:bg-slate-700">
          <a href={`/tag/${tag}`}>{tag}</a>
        </li>
      ))}
    </ul>
  )}
</Layout>
