# Astro: canonical site URL (sitemap, absolute URLs, OAuth redirects)
# Set in Cloudflare as a non-secret var or in CI for `astro build`.
SITE=https://your-worker.your-subdomain.workers.dev

# Keystatic: enable GitHub-backed storage when set to `owner/repo` (public; required in client bundle).
# Leave unset for local filesystem mode (default in dev).
PUBLIC_KEYSTATIC_GITHUB_REPO=

# Keystatic GitHub App (from /keystatic → Create GitHub App wizard)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Required: at least 32 characters (Keystatic uses this for AES; shorter values throw and API routes return 500).
KEYSTATIC_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# With @astrojs/cloudflare, `astro dev` runs like a Worker — put the same KEYSTATIC_* values in
# `.dev.vars` (gitignored) so the dev server sees them. `.env` alone is not always enough.
