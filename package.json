{
  "name": "@keystatic/templates-astro",
  "version": "0.0.63",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Thinkmill/keystatic/",
    "directory": "templates/astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/react": "^4.4.0",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "astro": "^5.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:prepare-assets": "rm -rf .wrangler-assets && mkdir -p .wrangler-assets && cp -R dist/. .wrangler-assets/ && rm -rf .wrangler-assets/_worker.js",
    "deploy:worker": "pnpm run deploy:prepare-assets && wrangler deploy dist/_worker.js --assets .wrangler-assets && rm -rf .wrangler-assets",
    "deploy": "astro build && pnpm run deploy:worker",
    "wrangler": "wrangler",
    "cf:types": "wrangler types --include-runtime false"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "wrangler": "^4.83.0",
    "tailwindcss": "^4.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
